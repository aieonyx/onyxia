{
  "productName": "Onyxia",
  "version": "1.0.0",
  "identifier": "com.aieonyx.onyxia",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npx vite --config vite.config.ts",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self' asset: https://asset.localhost; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' asset: https://asset.localhost ws://localhost:1420",
      "dangerousDisableAssetCspModification": false,
      "freezePrototype": true,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/onyxia/**",
          "$HOME/.config/onyxia/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libsecret-1-0",
          "libgtk-3-0"
        ]
      }
    }
  }
}