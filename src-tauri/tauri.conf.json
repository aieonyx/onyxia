{
  "productName": "Onyxia",
  "version": "0.1.0",
  "identifier": "com.aieonyx.onyxia",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npx vite --config vite.config.ts",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "Onyxia",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: https://asset.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self'",
      "dangerousDisableAssetCspModification": false,
      "freezePrototype": true,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/onyxia/**",
          "$HOME/.config/onyxia/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libsecret-1-0",
          "libgtk-3-0"
        ]
      }
    }
  }
}